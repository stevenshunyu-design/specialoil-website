# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Resend Email Configuration
RESEND_API_KEY=re_your_api_key
FROM_EMAIL=noreply@cnspecialtyoils.com
SITE_URL=https://cnspecialtyoils.com

# Feishu Webhook (Optional)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook

# hCaptcha Configuration (Required for form protection)
HCAPTCHA_SECRET=your_hcaptcha_secret_key_here
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key_here

# OpenAI API Configuration (For AI Chat Assistant)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_HOST=api.chatanywhere.tech

# Server Port (Hostinger will set this automatically)
PORT=3000
