# Feishu Webhook (Optional)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook

# hCaptcha Configuration (Required for form protection)
HCAPTCHA_SECRET=your_hcaptcha_secret_key_here
VITE_HCAPTCHA_SITE_KEY=80a2bfa8-da8c-4326-bada-a5e8ad02727e

# Server Port (Hostinger will set this automatically)
PORT=3000
