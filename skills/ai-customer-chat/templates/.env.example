# AI Customer Chat System 环境变量配置

# ==================== 必需配置 ====================

# Supabase 数据库配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI API 配置
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_HOST=api.openai.com

# 网站地址（用于飞书通知中的链接）
SITE_URL=https://your-website.com

# ==================== 可选配置 ====================

# 飞书客服通知 Webhook（新客户咨询时通知客服）
FEISHU_CHAT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-key

# 飞书询价通知 Webhook（客户提交询价表单时通知）
# 如果不配置，将使用 FEISHU_CHAT_WEBHOOK
FEISHU_INQUIRY_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-inquiry-webhook-key

# 端口（默认 3001）
PORT=3001

# 环境
NODE_ENV=production
